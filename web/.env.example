# Supabase project (Settings → API in the Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Public URL of this deployment — used for Supabase auth redirect URLs
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# GitHub token with contents:write on GITHUB_REPO, used to read/write
# newsletter/subscribers.json via the Contents API
GITHUB_TOKEN=ghp_...
GITHUB_REPO=lubospernis/safe_ai
GITHUB_SUBSCRIBERS_PATH=newsletter/subscribers.json
